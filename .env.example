# TRAX environment — copy to .env and fill in.
# These are Supabase *publishable* (anon) keys, safe to expose to the browser.
# If they're absent, the app falls back to the bundled public/data/pricing.json.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Server-side equivalents (used during SSR)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
SUPABASE_PROJECT_ID=your-project-id
